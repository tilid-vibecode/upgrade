# Root environment file for local backend development.
# Copy to .env in the repository root before running `cd server && honcho start`.

# Django
DJANGO_SECRET_KEY=replace-me-for-local-dev
DJANGO_DEBUG=true
DJANGO_ENVIRONMENT=development
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=https://localhost:3000,http://localhost:3000,http://localhost:5173
FRONTEND_URL=https://localhost:3000

# Database
DATABASE_URL=postgresql://upg:upg@localhost:5432/upg

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_SSL=false
REDIS_TIMEOUT=5
REDIS_POOL_MAX=50

# MinIO / S3-compatible storage
MINIO_ENDPOINT_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
PROCESSING_STORAGE_BACKEND=local_minio
PROCESSING_STORAGE_BUCKET=upg-processing
PROCESSING_LIFECYCLE_TTL_DAYS=7
PERSISTENT_STORAGE_BACKEND=local_minio
PERSISTENT_STORAGE_BUCKET=upg-persistent
STATIC_STORAGE_BACKEND=local_minio
STATIC_STORAGE_BUCKET=upg-static

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_HTTPS=false

# Optional LLM integrations
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_USAGE_LOGGING_ENABLED=false
