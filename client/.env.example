# ---------------------------------------------------------------------------
# Client — Environment Variables
# ---------------------------------------------------------------------------
# Vite exposes variables prefixed with VITE_ to the browser.
#
# Since the frontend and backend can live on different
# domains, VITE_API_BASE_URL must be set in deployed environments.
# Only local dev uses the Vite proxy.
# ---------------------------------------------------------------------------

# Local dev:     empty → Vite proxy forwards /api to localhost:8000
# Staging:       https://api-staging.example.com
# Production:    https://api.example.com
VITE_API_BASE_URL=

# Optional local override for Vite proxy target.
# Default is https://localhost:8000
# Set to http://localhost:8000 if you run backend without local certs.
VITE_DEV_API_TARGET=
